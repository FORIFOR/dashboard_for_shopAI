# ShopAI dashboard — copy to .env and fill in. NEVER commit the real .env.
# Used by docker-compose.monitoring.yml on the Backend VM (192.168.0.6).

# Grafana admin login (web UI at http://192.168.0.6:3000)
GRAFANA_ADMIN_PASSWORD=change-me-to-a-long-random-string

# Existing ShopAI PostgreSQL password (for postgres-exporter DATA_SOURCE_NAME).
# Must match the password of the application DB user that postgres-exporter connects as.
POSTGRES_PASSWORD=current-shopai-db-password

# Read-only PostgreSQL user that Grafana uses to read business tables
# (staff_calls, question_logs). Create it with sql/grafana_readonly_user.sql.
SHOPAI_DASHBOARD_DB_PASSWORD=another-long-random-string
