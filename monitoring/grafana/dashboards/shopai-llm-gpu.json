      "type": "gauge",
      "title": "GPU Util",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75.0
              },
              {
                "color": "red",
                "value": 90.0
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "shopai_gpu_utilization_percent",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
