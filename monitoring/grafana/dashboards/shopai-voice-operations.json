{
  "uid": "shopai-voice-operations",
  "title": "ShopAI Voice & Operations",
  "tags": [
    "shopai",
    "voice",
    "staff"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "TTS success rate",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(shopai_tts_jobs_total{status=\"completed\"}[5m])) / clamp_min(sum(rate(shopai_tts_jobs_total[5m])), 1)",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "TTS p95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(shopai_tts_duration_seconds_bucket[5m])))",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Playback finished rate",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(shopai_events_total{event_type=\"tts_playback_finished\"}[5m])) / clamp_min(sum(rate(shopai_events_total{event_type=\"tts_requested\"}[5m])), 1)",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Staff calls pending",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(shopai_staff_calls_total) - sum(shopai_staff_calls_total{status=\"resolved\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TTS jobs by status (rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(shopai_tts_jobs_total[5m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
          },
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Android events by type (rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event_type) (rate(shopai_events_total[5m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
          },
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Pending staff calls (PostgreSQL)",
      "datasource": {
        "type": "postgres",
        "uid": "shopai-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT created_at AS time, location_id, device_id, reason, status FROM staff_calls WHERE status = 'pending' ORDER BY created_at DESC LIMIT 20;",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "shopai-postgres"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent device auth rejections (PostgreSQL)",
      "datasource": {
        "type": "postgres",
        "uid": "shopai-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT created_at AS time, device_id, location_id, reason FROM auth_events WHERE result = 'rejected' ORDER BY created_at DESC LIMIT 20;",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "shopai-postgres"
          }
        }
      ]
    }
  ]
}
