      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT created_at AS time, location_id, route, answer_source, model_used, handoff_reason FROM question_logs WHERE answer_source = 'safe_fallback' ORDER BY created_at DESC LIMIT 20;",
