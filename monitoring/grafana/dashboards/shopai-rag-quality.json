    },
    {
      "id": 8,
      "type": "stat",
      "title": "Grounded answer rate (1 - fallback)",
      "datasource": {
        "type": "prometheus",
        "uid": "shopai-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (sum(rate(shopai_fallback_total[1h])) / clamp_min(sum(rate(shopai_chat_requests_total[1h])), 1))",
          "datasource": {
            "type": "prometheus",
            "uid": "shopai-prometheus"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top no-hit questions (PostgreSQL)",
      "datasource": {
        "type": "postgres",
        "uid": "shopai-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, location_id, route, count(*) AS no_hit FROM question_logs WHERE answer_source = 'safe_fallback' AND created_at >= now() - interval '24 hours' GROUP BY 1, 2, 3 ORDER BY no_hit DESC LIMIT 20;",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "shopai-postgres"
          }
        }
      ]
    }
  ]
}
